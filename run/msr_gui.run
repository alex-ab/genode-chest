create_boot_directory

import_from_depot [depot_user]/src/[base_src] \
                  [depot_user]/pkg/[drivers_interactive_pkg] \
                  [depot_user]/pkg/font \
                  [depot_user]/src/boot_fb \
                  [depot_user]/src/init \
                  [depot_user]/src/nitpicker \
                  [depot_user]/src/dynamic_rom \
                  [depot_user]/src/menu_view_ab \
                  [depot_user]/src/libc \
                  [depot_user]/src/libpng \
                  [depot_user]/src/zlib

if {[have_include "power_on/qemu"]} {
	set use_framebuffer "vesa_fb"
} else {
	set use_framebuffer "boot_fb"
}

set use_msr_native ![have_include "power_on/qemu"]

set build_components { app/msr_gui app/menu_view_ab core kernel lib/ld }

append_if [expr $use_msr_native] build_components { app/msr }

build $build_components

append config {
config | prio_levels: 4
+ parent-provides
  + service ROM
  + service IRQ
  + service IO_MEM
  + service IO_PORT
  + service PD
  + service RM
  + service CPU
  + service LOG
  + service TRACE
+ default-route
  + any-service
    + parent
    + any-child
+ default | caps: 200

+ start timer | caps: 200 | ram: 1M
  + provides
    + service Timer

+ start drivers | priority: -2 | ram: 72M | caps: 1500 | managing_system: yes
  + binary init
  + route
    + service ROM | label: config
    | + parent | label: drivers.config
    + service Timer
    | + child timer
    + service Capture
    | + child nitpicker
    + service Event
    | + child nitpicker
    + service ROM | label: vesa_fb
    | + parent | label: } $use_framebuffer {
    + any-service
      + parent

+ start nitpicker | ram: 4M | caps: 200 | priority: -1
  + provides
  | + service Gui
  | + service Capture
  | + service Event
  + config
    + capture
    + event
    + background
    |            color: #123456
    + domain pointer
    |        layer:   1
    |        content: client
    |        label:   no
    |        origin:  pointer
    + domain default
    |        layer:   3
    |        content: client
    |        label:   no
    |        hover:   always
    |        focus:   click
    + policy
    |        label_prefix: pointer
    |        domain:       pointer
    + default-policy
                     domain: default

+ start pointer | ram: 2M | caps: 200 | priority: -1
  + route
    + service Gui
    | + child nitpicker
    + any-service
      + parent
      + any-child

+ start report_rom | ram: 2M | caps: 200 | priority: -2
  + provides
  | + service Report
  | + service ROM
  + config | verbose: yes
    + policy | label:  menu_view -> dialog | report: msr_gui -> dialog
    + policy | label:  msr_gui -> hover    | report: menu_view -> hover
    + policy | label:  msr_gui -> info     | report: msr -> info
    + policy | label:  msr -> config       | report: msr_gui -> config

+ start font | ram: 8M | caps: 300 | priority: -2
  + binary vfs
  + route
  | + service ROM | label: config
  | | + parent | label: font.config
  | + any-service
  |   + parent
  + provides
    + service File_system

+ start menu_view | ram: 12M | caps: 200 | priority: -3
  + binary menu_view_ab
  + config
  | + report | hover: yes
  | + libc | stderr: /dev/log
  | + vfs
  | | + tar menu_view_style.tar
  | | + dir dev
  | | | + log
  | | + dir font
  | |   + fs | label: fonts
  | + dialog dialog | xpos: 200 | ypos: 100
  + route
    + service ROM | label: dialog
    | + child report_rom
    + service Report | label: hover
    | + child report_rom
    + service File_system | label: fonts
    | + child font | resource: /
    + any-service
      + parent
      + any-child }

