append config {
+ start msr_gui | ram: 2M | caps: 200 | priority: -3
  + route
    + service ROM | label: hover | + child report_rom }

append_if [expr !$use_msr_native] config {
    + service ROM | label: info  | + child dynamic_rom }

append_if [expr $use_msr_native] config {
    + service ROM | label: info  | + child report_rom }

append config {
    + any-service
      + parent
      + any-child }

append_if [expr $use_msr_native] config {
+ start msr | ram: 2M | caps: 200 | ld: yes | managing_system: yes | priority: -2
  + route
    + service ROM | label: config        | + child report_rom
    + service ROM | label: platform_info | + parent | label: platform_info
    + service Report                     | + child report_rom
    + service Timer                      | + child timer
    + any-service
      + parent }

append config {
-
}

set fb_cfg_fd [open "bin/fb_drv.config" w]
puts $fb_cfg_fd {config | width: 1280 | height: 1024
-}
close $fb_cfg_fd

set boot_modules { fb_drv.config }

install_config $config

lappend boot_modules {*}[build_artifacts]
build_boot_image $boot_modules

run_genode_until forever
